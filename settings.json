{
  "env": {
    "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_PAT>"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/gsd-check-update.js\""
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/vault-session-context.js\"",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/memory-obsidian-sync.js\"",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/claude-peers-start.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/memory-consolidation.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/memory-obsidian-sync.js\"",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/tg-session-end-notify.js\"",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/vault-session-logger.js\"",
            "timeout": 150,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/session-distill.js\"",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/tg-session-summary.js\"",
            "if": "Write(*-session.tmp)",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/tool-failure-logger.js\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/Rohan/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"C:/Users/Rohan/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "qmd@tobi": true,
    "claude-mem@thedotmack": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "ai-firstify@claude-plugins-official": false,
    "adspirer-ads-agent@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "supabase@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "zoominfo@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "tobi": {
      "source": {
        "source": "github",
        "repo": "tobi/qmd"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}