{
  "_comment": "MCP server configurations — merged into ~/.claude.json by restore.sh",
  "mcpServers": {
    "gitnexus": {
      "command": "node",
      "args": ["${NPM_GLOBAL_ROOT}/gitnexus/dist/cli/index.js", "mcp"],
      "type": "stdio",
      "install": "npm install -g gitnexus"
    },
    "qmd": {
      "command": "node",
      "args": ["${NPM_GLOBAL_ROOT}/@tobilu/qmd/dist/cli/qmd.js", "mcp"],
      "install": "npm install -g @tobilu/qmd"
    },
    "pencil": {
      "command": "${PENCIL_PATH}/resources/app.asar.unpacked/out/mcp-server-${PLATFORM}.exe",
      "args": ["--app", "desktop"],
      "env": {},
      "type": "stdio",
      "install": "Install Pencil desktop app from https://pencil.li"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${HOME}/.claude/memory-graph/knowledge.json"
      },
      "type": "stdio",
      "install": "Auto-installed via npx"
    },
    "claude-peers": {
      "url": "http://localhost:7355/mcp",
      "install": "Starts automatically via claude-peers-start.js hook"
    }
  }
}
